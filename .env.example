# nNmori - Environment Variables
# Copy this file to .env and fill in your values

# JWT Secret (REQUIRED - Change in production!)
JWT_SECRET=dev-secret-do-not-use-in-production

# Database (PostgreSQL)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# API Base URL (leave empty for web, set for native Capacitor builds)
# e.g. https://app.numori.app
NUXT_PUBLIC_API_BASE=

# CORS allowed origins (comma-separated, leave empty to allow all in dev)
# e.g. https://app.numori.app,capacitor://localhost
CORS_ORIGINS=
